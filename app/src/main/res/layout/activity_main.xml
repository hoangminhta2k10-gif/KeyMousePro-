<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎮 KeyMousePro"
        android:textColor="#00e676"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Gaming Peripheral Manager"
        android:textColor="#55556a"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="#1c1c2e" />

    <Button
        android:id="@+id/btnConnect"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#00e676"
        android:text="Kết nối ADB Local"
        android:textColor="#000000"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnPair"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:backgroundTint="#18182a"
        android:text="Ghép nối Wireless Debugging"
        android:textColor="#448aff" />

    <EditText
        android:id="@+id/etPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="Port ADB (ví dụ: 5555)"
        android:inputType="number"
        android:textColor="#eeeeff"
        android:textColorHint="#55556a" />

    <EditText
        android:id="@+id/etPairingCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Mã ghép nối 6 số"
        android:inputType="number"
        android:textColor="#eeeeff"
        android:textColorHint="#55556a" />

    <TextView
        android:id="@+id/tvConnectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="● Chưa kết nối"
        android:textColor="#ff1744"
        android:textSize="13sp" />

</LinearLayout>
