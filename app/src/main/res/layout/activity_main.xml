<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a1e">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🎮 KeyMousePro"
                android:textColor="#00e676"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Chưa kết nối"
                android:textColor="#ff1744"
                android:textSize="11sp"
                android:background="#1c1c2e"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

        <!-- BƯỚC 1: Quyền -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BƯỚC 1 — CẤP QUYỀN"
            android:textColor="#00e676"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#10102a"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <!-- Overlay -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🪟  Quyền cửa sổ nổi"
                    android:textColor="#eef0ff"
                    android:textSize="14sp"/>

                <Button
                    android:id="@+id/btnGrantOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="CẤP QUYỀN"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:backgroundTint="#00e676"/>

            </LinearLayout>

            <!-- Background -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="⚡  Quyền chạy nền"
                    android:textColor="#eef0ff"
                    android:textSize="14sp"/>

                <Button
                    android:id="@+id/btnGrantBattery"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="CẤP QUYỀN"
                    android:textSize="11sp"
                    android:textColor="#000000"
                    android:backgroundTint="#00e676"/>

            </LinearLayout>

        </LinearLayout>

        <!-- BƯỚC 2: Hướng dẫn -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BƯỚC 2 — BẬT WIRELESS DEBUGGING"
            android:textColor="#00e676"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#10102a"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Vào Cài đặt → Giới thiệu về điện thoại\n   → Nhấn 7 lần vào Số hiệu bản dựng\n\n2. Quay lại Cài đặt → Tùy chọn nhà phát triển\n\n3. Bật Gỡ lỗi không dây (Wireless Debugging)\n\n4. Mở Wireless Debugging → Ghi nhớ số Port\n   (VD: Địa chỉ IP và cổng: 192.168.1.5:38721\n    → Port cần nhập là: 38721)"
                android:textColor="#6677aa"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnOpenDevOptions"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="⚙️ Mở Tùy chọn nhà phát triển"
                android:textColor="#448aff"
                android:textSize="12sp"
                android:backgroundTint="#141436"/>

        </LinearLayout>

        <!-- BƯỚC 3: Nhập port -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BƯỚC 3 — NHẬP PORT VÀ KẾT NỐI"
            android:textColor="#00e676"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#10102a"
            android:padding="14dp"
            android:layout_marginBottom="20dp">

            <EditText
                android:id="@+id/etPort"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Nhập Port từ màn hình Wireless Debugging"
                android:inputType="number"
                android:textColor="#eef0ff"
                android:textColorHint="#33334a"
                android:textSize="15sp"
                android:backgroundTint="#1c1c2e"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 Kết nối lần đầu: Sẽ hiện hộp thoại 'Cho phép gỡ lỗi qua USB' → Nhấn Cho phép → App tự kết nối lại"
                android:textColor="#33334a"
                android:textSize="11sp"
                android:layout_marginBottom="14dp"/>

            <Button
                android:id="@+id/btnConnect"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="🔗  Kết nối ADB"
                android:textColor="#000000"
                android:textStyle="bold"
                android:textSize="15sp"
                android:backgroundTint="#00e676"/>

        </LinearLayout>

        <!-- Status Box -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chờ kết nối..."
            android:textColor="#6677aa"
            android:textSize="12sp"
            android:background="#10102a"
            android:padding="14dp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp"/>

        <!-- Gaming Mode Button -->
        <Button
            android:id="@+id/btnGaming"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="▶  Bắt đầu Gaming Mode"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="16sp"
            android:backgroundTint="#7c4dff"
            android:enabled="false"/>

    </LinearLayout>
</ScrollView>
