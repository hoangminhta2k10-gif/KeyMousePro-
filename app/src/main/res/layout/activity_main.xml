<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080810"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="🎮 KeyMousePro"
                android:textColor="#00e676"
                android:textSize="19sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Offline"
                android:textColor="#ff1744"
                android:textSize="11sp"
                android:background="#0d0d20"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#10102a"
            android:padding="24dp"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <TextView
                android:id="@+id/tvEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏸"
                android:textSize="52sp"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chưa kết nối"
                android:textColor="#eef0ff"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#6677aa"
                android:textSize="12sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"/>

        </LinearLayout>

        <!-- Progress Steps -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0d0d22"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="14dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                <TextView android:id="@+id/s1i" android:layout_width="30dp" android:layout_height="wrap_content" android:text="○" android:textColor="#2a2a40" android:textSize="16sp"/>
                <TextView android:id="@+id/s1t" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tìm thiết bị" android:textColor="#2a2a40" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                <TextView android:id="@+id/s2i" android:layout_width="30dp" android:layout_height="wrap_content" android:text="○" android:textColor="#2a2a40" android:textSize="16sp"/>
                <TextView android:id="@+id/s2t" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ghép nối" android:textColor="#2a2a40" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="2dp">
                <TextView android:id="@+id/s3i" android:layout_width="30dp" android:layout_height="wrap_content" android:text="○" android:textColor="#2a2a40" android:textSize="16sp"/>
                <TextView android:id="@+id/s3t" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kết nối ADB" android:textColor="#2a2a40" android:textSize="13sp"/>
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="38dp" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:id="@+id/s4i" android:layout_width="30dp" android:layout_height="wrap_content" android:text="○" android:textColor="#2a2a40" android:textSize="16sp"/>
                <TextView android:id="@+id/s4t" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sẵn sàng" android:textColor="#2a2a40" android:textSize="13sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Pairing Code Input -->
        <LinearLayout
            android:id="@+id/layoutCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#10102a"
            android:padding="16dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MÃ GHÉP NỐI"
                android:textColor="#00e676"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp"/>

            <EditText
                android:id="@+id/etCode"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:hint="6 số"
                android:inputType="number"
                android:maxLength="6"
                android:textColor="#eef0ff"
                android:textColorHint="#33334a"
                android:textSize="28sp"
                android:gravity="center"
                android:textStyle="bold"
                android:backgroundTint="#1c1c38"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnCode"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="✓  Xác nhận"
                android:textColor="#000000"
                android:textStyle="bold"
                android:backgroundTint="#00e676"/>

        </LinearLayout>

        <!-- Solution Box -->
        <LinearLayout
            android:id="@+id/layoutFix"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1a0808"
            android:padding="14dp"
            android:layout_marginBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CÁCH KHẮC PHỤC"
                android:textColor="#ff6935"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvFix"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#aa8877"
                android:textSize="13sp"
                android:lineSpacingExtra="5dp"/>

        </LinearLayout>

        <!-- Main Button -->
        <Button
            android:id="@+id/btnMain"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="🔍  Tìm kiếm tự động"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="15sp"
            android:backgroundTint="#00e676"
            android:layout_marginBottom="10dp"/>

        <!-- Helper Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnPerm"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="🔓 Quyền"
                android:textColor="#448aff"
                android:textSize="12sp"
                android:backgroundTint="#0d0d22"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnDev"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="44dp"
                android:text="⚙️ Dev Options"
                android:textColor="#bb86fc"
                android:textSize="12sp"
                android:backgroundTint="#0d0d22"/>

        </LinearLayout>

        <!-- Gaming Mode Button -->
        <Button
            android:id="@+id/btnGame"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="▶  Bắt đầu Gaming Mode"
            android:textColor="#000000"
            android:textStyle="bold"
            android:textSize="15sp"
            android:backgroundTint="#7c4dff"
            android:enabled="false"/>

    </LinearLayout>
</ScrollView>
